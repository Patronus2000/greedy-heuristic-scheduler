    "B": { "chargers": [{ "id": "B-1", "charge_duration_min": 25 }] },
    "C": { "chargers": [{ "id": "C-1", "charge_duration_min": 25 }] },
    "D": { "chargers": [{ "id": "D-1", "charge_duration_min": 25 }] }
  },
  "vehicle_defaults": { "battery_range_km": 240, "speed_kmh": 60 },
  "weights": { "individual_wait": 1.0, "operator_fairness": 1.0, "overall_time": 1.0 },
